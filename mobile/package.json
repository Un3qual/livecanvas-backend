{
  "name": "livecanvas-mobile",
  "version": "1.0.0",
  "main": "./index.ts",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "relay": "relay-compiler",
    "lint": "eslint . --max-warnings=0",
    "test:bun": "bun test --preload ./tests/setup/reactNative.ts tests",
    "test:jest": "jest --config ./jest.config.js",
    "test:quality": "bun run typecheck && bun run typecheck:tests && bun run lint && bun run test:bun && bun run test:jest",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json && tsc --noEmit -p tsconfig.jest-tests.json"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@xstate/react": "^6.1.0",
    "expo": "~55.0.8",
    "expo-apple-authentication": "~55.0.13",
    "expo-auth-session": "~55.0.13",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.35",
    "expo-image-picker": "~55.0.21",
    "expo-keep-awake": "~55.0.8",
    "expo-router": "^55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.14",
    "graphql": "^16.13.2",
    "phoenix": "^1.8.7",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-webrtc": "^124.0.7",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "xstate": "^5.32.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/bun": "^1.3.14",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "babel-plugin-relay": "^20.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.19",
    "relay-compiler": "^20.1.1",
    "test-renderer": "^1.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.0"
  },
  "private": true,
  "packageManager": "pnpm@10.32.1"
