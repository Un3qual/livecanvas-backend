{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "channel": "production"
    },
    "preview": {
      "extends": "production",
      "distribution": "internal",
      "channel": "preview"
    },
    "development": {
      "extends": "preview",
      "developmentClient": true,
      "channel": "development"
    }
  }
}
