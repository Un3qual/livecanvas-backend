<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content="" />
    <title>Open your LiveCanvas invite</title>
    <link rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <main data-contact-invite-landing>
      <h1>Open this invite in LiveCanvas</h1>
      <p data-contact-invite-state>This invite is invalid or expired.</p>
      <a hidden data-contact-invite-action>Open in LiveCanvas</a>
    </main>
  </body>
</html>
