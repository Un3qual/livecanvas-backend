<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Open your LiveCanvas email link</title>
    <link rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer type="text/javascript" src={~p"/assets/js/magic_link_landing_entry.js"}>
    </script>
  </head>
  <body>
    <main data-magic-link-landing>
      <h1>Open your LiveCanvas email link</h1>
      <p data-magic-link-state>This email link is invalid or expired.</p>
      <a hidden data-magic-link-action>Open in LiveCanvas</a>
    </main>
  </body>
</html>
